  /// JSON string[]
  targetUsers             String    @default("[]") @map("target_users")
  /// JSON string[]
  productsServices        String    @default("[]") @map("products_services")
  supportKnowledge        String    @default("") @map("support_knowledge")
  /// JSON string[]
  contentTopics           String    @default("[]") @map("content_topics")
  /// JSON string[]
  risks                   String    @default("[]")
  /// JSON string[]
  recommendedCapabilities String    @default("[]") @map("recommended_capabilities")
  /// JSON object — model package recommendation
