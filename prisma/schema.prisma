  importance  Float    @default(0.5) // 0.0–1.0
  tags        String   @default("[]") @map("tags") // JSON string[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([memoryType])
  @@map("aiva_memories")
}

// ── PHASE 3 — App Intelligence Profiles ─────────────────────────────────────

/// Per-app intelligence profile generated by Firecrawl + Brain summarisation.
/// Stores structured business context used by Aiva, workspace, and agents.
model AppIntelligenceProfile {
