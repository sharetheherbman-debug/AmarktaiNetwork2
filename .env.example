DATABASE_URL="postgresql://user:password@host:5432/amarktai_network"
SESSION_SECRET="your-super-secret-session-key-min-32-chars"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Admin credentials used by /admin/login when no DB admin user exists.
# ADMIN_EMAIL defaults to admin@amarktai.network if not set.
# Both must be set together in production for the env-var fallback to work.
ADMIN_EMAIL="admin@amarktai.network"
ADMIN_PASSWORD="your-secure-admin-password"
# AI Provider keys are stored server-side in the ai_providers DB table — NOT in env vars.
# Use the Admin > AI Providers vault page to configure provider API keys securely.
# No additional env vars required for the AI Provider Vault.
