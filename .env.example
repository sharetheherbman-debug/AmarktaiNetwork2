# ─────────────────────────────────────────────────────────────────────────────
# AmarktAI Network — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running the app.
# DO NOT commit .env to version control.
#
# IMPORTANT: Placeholder/example values in this file will be rejected at runtime
# by the config validator. You MUST provide real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (required) ───────────────────────────────────────────────────────
#
# PostgreSQL connection string. Must point to a real, reachable database.
# Supported providers: Neon, Supabase, PlanetScale (via Prisma), Railway, etc.
#
# Examples:
#   Neon:      postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#   Railway:   postgresql://postgres:pass@containers-us-west-xxx.railway.app:5432/railway
#   Supabase:  postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
#
# The config validator will REJECT placeholder values such as:
#   postgresql://user:password@host:5432/...    ← rejected (placeholder host/user/password)
#   postgresql://postgres:postgres@localhost:5432/... ← rejected (localhost)
#
DATABASE_URL="postgresql://REPLACE_USER:REPLACE_PASSWORD@REPLACE_HOST:5432/amarktai_network"

# ── Session secret (required) ─────────────────────────────────────────────────
#
# Random string of at least 32 characters used to sign admin session cookies.
# Generate one with: openssl rand -hex 32
# Must NOT be the placeholder value below — the config validator will reject it.
#
SESSION_SECRET="REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32"

# ── Public app URL (recommended) ──────────────────────────────────────────────
#
# The public-facing base URL of the app. Used for OAuth callbacks and links.
# In development, this is typically http://localhost:3000.
# In production, set this to your actual domain (https://amarktai.network).
#
NEXT_PUBLIC_APP_URL="https://amarktai.network"

# ── Admin credentials (optional fallback) ────────────────────────────────────
#
# Used only when there is no AdminUser row in the database.
# If ADMIN_EMAIL is set, ADMIN_PASSWORD is also required for the fallback to work.
# In production, create a real DB admin user via the dashboard or seed script.
#
ADMIN_EMAIL="admin@amarktai.network"
ADMIN_PASSWORD="REPLACE_WITH_SECURE_ADMIN_PASSWORD"

# ── AI Provider keys ──────────────────────────────────────────────────────────
#
# AI provider API keys are stored securely in the database via the
# Admin > AI Providers dashboard page — NOT in environment variables.
# Do NOT put provider API keys here.
#
# Use the dashboard at /admin/dashboard/ai-providers to configure:
#   - OpenAI, Groq, DeepSeek, Gemini, xAI / Grok
#   - Hugging Face, NVIDIA NIM, OpenRouter, Together AI
#   - Anthropic (Claude), Cohere (Rerank/Embed), Replicate, Qwen
#

# ── Vault encryption (recommended for production) ─────────────────────────────
#
# AES-256-GCM key used to encrypt AI provider API keys at rest in the database.
# Generate with: openssl rand -hex 32
# If not set, keys are stored in plaintext (acceptable for development only).
# In production, always set this to protect provider credentials.
#
# VAULT_ENCRYPTION_KEY="REPLACE_WITH_OUTPUT_OF_openssl_rand_hex_32"

# ── Infrastructure (optional — enhanced features) ────────────────────────────
#
# Redis: Used for caching, rate limiting, emotion persistence, and pub/sub.
# When running with docker-compose, this is automatically set.
# REDIS_URL="redis://localhost:6379"
#
# Qdrant: Vector database for semantic search, RAG, and long-term emotion memory.
# When running with docker-compose, this is automatically set.
# QDRANT_URL="http://localhost:6333"
# QDRANT_API_KEY=""
#
# HuggingFace: Enables live emotion enrichment via HF Inference API.
# When set, the emotion engine calls roberta/distilroberta models for
# enhanced emotion detection and blends results with the internal engine.
# Free tier: 30k tokens/month. Get your key at https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=""
#
# Realtime Voice WebSocket Service:
#   The realtime service is included in this repo at services/realtime/server.js.
#   Start it with: cd services/realtime && npm install && OPENAI_API_KEY=sk-... node server.js
#   Or use Docker Compose: the 'realtime' service is pre-configured (port 8765).
#   Or deploy it as a systemd service: deploy/amarktai-realtime.service
#
#   Once running, set REALTIME_SERVICE_URL to enable the realtime_voice capability.
#   The value should be the HTTP URL of the running service (not ws://):
# REALTIME_SERVICE_URL="http://localhost:8765"
#
# ── External Integrations (optional — enhanced platform features) ─────────────
#
# Firecrawl: Website crawling for app understanding.
# Crawls connected app websites to extract structure, docs, and AI-use signals.
# Get your key at https://firecrawl.dev
# FIRECRAWL_API_KEY=""
# FIRECRAWL_API_URL="https://api.firecrawl.dev/v1"
#
# Mem0: Persistent app-isolated memory.
# Stores app-specific memories, preferences, and routing patterns.
# Get your key at https://mem0.ai
# MEM0_API_KEY=""
# MEM0_API_URL="https://api.mem0.ai/v1"
#
# Graphiti: Knowledge graph for app relationships and provenance.
# Tracks feature relationships, source provenance, and capability mapping.
# GRAPHITI_API_URL=""
# GRAPHITI_API_KEY=""
#
# GenX: Primary AI execution layer (GenX-first architecture)
#
# GenX is the primary execution layer for all AI tasks in the AmarktAI Network.
# All workspace and app AI requests are routed through GenX by default.
# Direct provider routing (openai/groq/etc.) is used only as a fallback when
# GenX is unavailable or returns an error.
#
# GENX_API_URL:  Base URL of the GenX API (no trailing slash).
#                Always use https://query.genx.sh — NOT https://genx.sh
#                (that is the dashboard/signup page and returns HTML, not JSON).
# GENX_API_KEY:  API key starting with gnxk_ (get yours at https://genx.sh).
# GENX_ADULT_CONTENT_SUPPORTED: Set to "true" only after verifying your GenX
#   deployment is licensed and configured for adult content. Defaults to false.
#
# GENX_API_URL="https://query.genx.sh"
# GENX_API_KEY="gnxk_..."
# GENX_ADULT_CONTENT_SUPPORTED="false"
#
# LiteLLM: Unified provider proxy for cost-aware routing.
# Provides consistent provider abstraction and fallback routing.
# LITELLM_API_URL=""
# LITELLM_API_KEY=""
#
# PostHog: Analytics and observability.
# Tracks usage, feature adoption, and request outcomes truthfully.
# Get your key at https://posthog.com
# POSTHOG_API_KEY=""
# POSTHOG_HOST="https://us.i.posthog.com"
#
# ── SMTP / Email (optional — contact form + alert notifications) ─────────────
#
# When configured, the contact form sends enquiries to CONTACT_EMAIL and
# system alerts are emailed to ALERT_EMAIL.
#
# Gmail example (use an App Password, not your account password):
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_PORT="587"
#   SMTP_USER="your-sender@gmail.com"
#   SMTP_PASS="your-16-char-app-password"
#   SMTP_FROM="AmarktAI Network <your-sender@gmail.com>"
#
# Generate a Gmail App Password at:
#   https://myaccount.google.com/apppasswords
#   (Note: 2-Step Verification must be enabled on your Google account first)
#
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM="AmarktAI Network <noreply@amarktai.network>"
# CONTACT_EMAIL="amarktainetwork@gmail.com"
# ALERT_EMAIL="amarktainetwork@gmail.com"
#
# LangGraph: Durable workflow orchestration.
# Falls back to internal workflow engine if not configured.
# LANGGRAPH_API_URL=""
# LANGGRAPH_API_KEY=""
#
# ── Storage (Phase 2 — artifact system) ───────────────────────────────────────
#
# Storage driver for generated artifacts (images, audio, video, code, docs).
# Options: local (default), s3, r2
# STORAGE_DRIVER="local"
# STORAGE_LOCAL_DIR=".storage"
#
# S3-compatible storage (AWS S3, MinIO, etc.):
# S3_BUCKET="amarktai-artifacts"
# S3_REGION="us-east-1"
# S3_ENDPOINT=""
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
#
# Cloudflare R2:
# R2_PUBLIC_URL=""
#
